+    #[test]
+    fn info_clients_refreshes_tracking_context_on_demand() {
+        let mut rt = Runtime::default_strict();
+
+        assert_eq!(
+            rt.execute_frame(command(&[b"CLIENT", b"TRACKING", b"ON"]), 0),
+            RespFrame::SimpleString("OK".to_string())
+        );
+        let out = rt.execute_frame(command(&[b"INFO", b"clients"]), 1);
+        let RespFrame::BulkString(Some(bytes)) = out else {
+            unreachable!("expected bulk string");
+        };
+        let info = String::from_utf8(bytes).expect("utf8");
+        assert!(info.contains("tracking_clients:1\r\n"), "{info}");
+    }
