+fn borrowed_action_from_args<'a>(
+    kind: BorrowedCommandArgsKind,
+    consumed: usize,
+    borrowed_args: &'a [&'a [u8]],
+    argv_scratch: &mut Vec<Vec<u8>>,
+    runtime: &mut Runtime,
+    ts: u64,
+) -> BorrowedMultibulkAction {
+    let argv_len = borrowed_args.len();
+    if matches!(kind, BorrowedCommandArgsKind::Arguments) && argv_len > 0 {
+        if let Some(response) = borrowed_fast_reply(borrowed_args, runtime, ts) {
+            return BorrowedMultibulkAction::FastReply { consumed, response };
+        }
+        copy_borrowed_argv_into_scratch(borrowed_args, argv_scratch);
+    }
+    BorrowedMultibulkAction::Parsed {
+        kind,
+        consumed,
+        argv_len,
+    }
+}
