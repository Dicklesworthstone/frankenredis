+/// Parse a strict RESP multibulk command into a fixed-size borrowed argv packet.
+/// Returns `Ok(None)` when the frame is valid so far but has more than `N`
+/// arguments; callers can fall back to [`parse_command_args_borrowed_into`].
+pub fn try_parse_command_args_borrowed_small<'a, const N: usize>(
+    input: &'a [u8],
+    config: &ParserConfig,
+) -> Result<Option<BorrowedCommandSmallArgsParseResult<'a, N>>, RespParseError> {
+    match input.first() {
+        Some(b'*') => {}
+        Some(&other) => return Err(RespParseError::InvalidPrefix(other)),
+        None => return Err(RespParseError::Incomplete),
+    }
+    let (line, mut cursor) = read_line(input, 1)?;
+    let len = parse_i64_strict(line).map_err(|_| RespParseError::InvalidMultibulkLength)?;
+    if len < 0 {
+        return Ok(Some(BorrowedCommandSmallArgsParseResult {
+            kind: BorrowedCommandArgsKind::NullArray,
+            consumed: cursor,
+            args: BorrowedCommandSmallArgs {
+                args: [&[]; N],
+                len: 0,
+            },
+        }));
+    }
+    let count = usize::try_from(len).map_err(|_| RespParseError::InvalidMultibulkLength)?;
+    if count > config.max_array_len {
+        return Err(RespParseError::MultibulkLengthTooLarge);
+    }
+    if count > N {
+        return Ok(None);
+    }
+
+    let mut args = BorrowedCommandSmallArgs {
+        args: [&[]; N],
+        len: 0,
+    };
+    for slot in 0..count {
+        match input.get(cursor) {
+            None => return Err(RespParseError::Incomplete),
+            Some(&b'$') => {}
+            Some(&other) => return Err(RespParseError::ExpectedBulk(other)),
+        }
+        let (arg, consumed) = parse_bulk_slice(input, cursor + 1, config)?;
+        let Some(arg) = arg else {
+            return Err(RespParseError::InvalidBulkLength);
+        };
+        args.args[slot] = arg;
+        args.len += 1;
+        cursor = consumed;
+    }
+    Ok(Some(BorrowedCommandSmallArgsParseResult {
+        kind: BorrowedCommandArgsKind::Arguments,
+        consumed: cursor,
+        args,
+    }))
+}
