+            }
+            SortedSetInner::Packed(_) => panic!("expected compact full zset"),
+        }
+
+        assert_eq!(
+            zs.score_bound_count(ScoreBound::Inclusive(100.0), ScoreBound::Inclusive(199.0)),
+            100
