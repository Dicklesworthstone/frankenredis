+        use super::{FullZSetOrder, ScoreBound, SortedSet, SortedSetInner};
+
+        let mut zs = SortedSet::new();
+        for i in 0..512 {
+            zs.insert(format!("member-{i:04}").into_bytes(), f64::from(i));
