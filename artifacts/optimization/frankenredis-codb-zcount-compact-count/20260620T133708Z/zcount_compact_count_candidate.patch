+    fn compact_range_window<R>(keys: &[ScoreMember], range: R) -> &[ScoreMember]
+    where
+        R: RangeBounds<ScoreMember>,
+    {
+        let start = match range.start_bound() {
+            Included(key) => keys.partition_point(|sm| sm < key),
+            Excluded(key) => keys.partition_point(|sm| sm <= key),
+            Unbounded => 0,
+        };
+        let end = match range.end_bound() {
+            Included(key) => keys.partition_point(|sm| sm <= key),
+            Excluded(key) => keys.partition_point(|sm| sm < key),
+            Unbounded => keys.len(),
+        };
+        let start = start.min(end);
+        keys.get(start..end).unwrap_or(&[])
+    }
