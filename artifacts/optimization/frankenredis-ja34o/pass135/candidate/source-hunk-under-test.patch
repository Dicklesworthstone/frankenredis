+    #[test]
+    fn writer_handoff_leaves_bounded_spare_write_buffer() {
+        use crate::{
+            ClientConnection, OutputDriveContext, WRITER_HANDOFF_SPARE_CAP_BYTES, WriterPool,
+            clone_writer_stream, drive_client_output,
+        };
+        use fr_runtime::Runtime;
+        use mio::{Poll, Token};
+        use std::collections::HashSet;
+
+        let mut runtime = Runtime::default_strict();
+        let session = runtime.new_session();
+        let listener = StdTcpListener::bind("127.0.0.1:0").unwrap();
+        let addr = listener.local_addr().unwrap();
+        let stream = StdTcpStream::connect(addr).unwrap();
+        let (_peer, _peer_addr) = listener.accept().unwrap();
+        let mio_stream = mio::net::TcpStream::from_std(stream);
+        let writer_stream = clone_writer_stream(&mio_stream).unwrap();
+        let mut conn =
+            ClientConnection::new_with_writer(mio_stream, Some(writer_stream), session, 0);
+        let payload_len = WRITER_HANDOFF_SPARE_CAP_BYTES + 4096;
+        conn.write_buf.resize(payload_len, b'x');
+
+        let mut poll = Poll::new().unwrap();
+        let pool = WriterPool::new(&poll).unwrap();
+        let mut write_tokens = HashSet::new();
+        let mut closing_tokens = HashSet::new();
+
+        drive_client_output(
+            Token(99),
+            &mut conn,
+            OutputDriveContext {
+                runtime: &mut runtime,
+                poll: &mut poll,
+                write_tokens: &mut write_tokens,
+                closing_tokens: &mut closing_tokens,
+                writer_pool: Some(&pool),
+            },
+            true,
+        );
+
+        assert_eq!(conn.writer_in_flight_bytes, payload_len);
+        assert!(conn.write_buf.is_empty());
+        assert!(
+            conn.write_buf.capacity() >= WRITER_HANDOFF_SPARE_CAP_BYTES,
+            "handoff should keep a spare output slab"
+        );
+        assert!(
+            conn.write_buf.capacity() <= payload_len,
+            "spare output slab should not exceed the handed-off batch"
+        );
+        assert!(write_tokens.contains(&Token(99)));
+        assert!(closing_tokens.is_empty());
+    }
+
