+    #[test]
+    fn set_plain_borrowed_matches_set_for_existing_persistent_values() {
+        for value in [
+            b"123".as_slice(),
+            b"x42".as_slice(),
+            b"007".as_slice(),
+            b"-42".as_slice(),
+        ] {
+            let mut expected = Store::new();
+            let mut actual = Store::new();
+
+            expected.set(b"k".to_vec(), b"old".to_vec(), None, 100);
+            actual.set(b"k".to_vec(), b"old".to_vec(), None, 100);
+            expected.set(b"k".to_vec(), value.to_vec(), None, 400);
+            actual.set_plain_borrowed(b"k", value, 400);
+
+            assert_eq!(actual.get(b"k", 401), expected.get(b"k", 401));
+            assert_eq!(
+                actual.object_encoding(b"k", 401),
+                expected.object_encoding(b"k", 401),
+                "encoding mismatch for {value:?}"
+            );
+            assert_eq!(
+                actual.memory_usage_for_key(b"k", 401),
+                expected.memory_usage_for_key(b"k", 401),
+                "memory usage mismatch for {value:?}"
+            );
+            assert_eq!(actual.expires_count, expected.expires_count);
+            assert_eq!(actual.db_expires_counts, expected.db_expires_counts);
+            assert_eq!(actual.dirty, expected.dirty, "dirty mismatch for {value:?}");
+            assert_eq!(
+                actual.state_digest(),
+                expected.state_digest(),
+                "digest mismatch for {value:?}"
+            );
+        }
+    }
