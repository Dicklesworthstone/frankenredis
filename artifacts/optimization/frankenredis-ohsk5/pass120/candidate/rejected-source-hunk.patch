+fn recycle_drained_writer_buffer(conn: &mut ClientConnection, bytes: Vec<u8>) {
+    debug_assert!(bytes.is_empty());
+    if conn.write_buf.is_empty() && bytes.capacity() > conn.write_buf.capacity() {
+        conn.write_buf = bytes;
