+    #[test]
+    fn drained_writer_buffer_reuse_preserves_pending_output() {
+        let listener = StdTcpListener::bind("127.0.0.1:0").unwrap();
+        let addr = listener.local_addr().unwrap();
+        let _client = StdTcpStream::connect(addr).unwrap();
+        let (server, _) = listener.accept().unwrap();
+        server.set_nonblocking(true).unwrap();
+
+        let runtime = Runtime::default_strict();
+        let session = runtime.new_session();
+        let mut conn =
+            crate::ClientConnection::new(mio::net::TcpStream::from_std(server), session, 1);
+
+        let mut drained = Vec::with_capacity(128);
+        drained.extend_from_slice(b"+OK\r\n");
+        drained.clear();
+        crate::recycle_drained_writer_buffer(&mut conn, drained);
+        assert!(conn.write_buf.is_empty());
+        assert!(conn.write_buf.capacity() >= 128);
+
+        conn.write_buf.extend_from_slice(b":1\r\n");
+        let queued = conn.write_buf.clone();
+        let larger_drained = Vec::with_capacity(conn.write_buf.capacity() + 64);
+        crate::recycle_drained_writer_buffer(&mut conn, larger_drained);
+        assert_eq!(conn.write_buf, queued);
+    }
