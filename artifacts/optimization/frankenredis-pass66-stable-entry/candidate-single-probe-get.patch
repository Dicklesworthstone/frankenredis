diff --git a/crates/fr-store/src/lib.rs b/crates/fr-store/src/lib.rs
index fa37316f8..5c41f02e1 100644
--- a/crates/fr-store/src/lib.rs
+++ b/crates/fr-store/src/lib.rs
@@ -4023,6 +4023,22 @@ impl Store {
     /// Get a string value. Returns `None` if the key doesn't exist.
     /// Returns `Err(WrongType)` if the key holds a non-string value.
     pub fn get(&mut self, key: &[u8], now_ms: u64) -> Result<Option<Vec<u8>>, StoreError> {
+        if self.volatile_keys.is_empty() && !self.lfu_tracking_enabled() {
+            match self.entries.get_mut(key) {
+                Some(entry) => {
+                    self.stat_keyspace_hits = self.stat_keyspace_hits.saturating_add(1);
+                    let Some(v) = entry.value.string_owned() else {
+                        return Err(StoreError::WrongType);
+                    };
+                    entry.touch(now_ms);
+                    return Ok(Some(v));
+                }
+                None => {
+                    self.stat_keyspace_misses = self.stat_keyspace_misses.saturating_add(1);
+                    return Ok(None);
+                }
+            }
+        }
         if !self.record_keyspace_lookup(key, now_ms) {
             return Ok(None);
         }
