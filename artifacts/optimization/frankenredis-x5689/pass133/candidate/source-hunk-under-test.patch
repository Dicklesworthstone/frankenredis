+struct BorrowedPlainGetRun {
+    consumed: usize,
+    frames: usize,
+}
+
 struct BorrowedPlainGetPacket<'a> {
     consumed: usize,
     key: &'a [u8],
 }
 
+fn execute_borrowed_plain_get_run(
+    input: &[u8],
+    config: &ParserConfig,
+    runtime: &mut Runtime,
+    ts: u64,
+    out: &mut Vec<u8>,
+    plain_get_read_gate_cache: &mut Option<bool>,
+    frame_budget: usize,
+) -> Option<BorrowedPlainGetRun> {
+    let mut consumed = 0usize;
+    let mut frames = 0usize;
+    let client_resp3 = runtime.client_session().resp_protocol_version() == 3;
+
+    while frames < frame_budget {
+        let Some(remaining) = input.get(consumed..) else {
+            break;
+        };
+        let Some(packet) = parse_borrowed_plain_get_packet(remaining, config) else {
+            break;
+        };
+        let default_read_allowed = *plain_get_read_gate_cache
+            .get_or_insert_with(|| runtime.plain_borrowed_default_key_read_gate(ts));
+        if !default_read_allowed {
+            return None;
+        }
+        if runtime
+            .execute_plain_get_borrowed_into_with_default_read_gate(
+                packet.key,
+                ts,
+                client_resp3,
+                out,
+                default_read_allowed,
+            )
+            .is_none()
+        {
+            break;
+        }
+        consumed += packet.consumed;
+        frames += 1;
+    }
+
+    (frames > 0).then_some(BorrowedPlainGetRun { consumed, frames })
+}
