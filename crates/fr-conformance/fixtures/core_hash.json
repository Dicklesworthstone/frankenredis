{
  "suite": "core_hash",
  "cases": [
    {
      "name": "hset_single_field",
      "now_ms": 0,
      "argv": ["HSET", "h1", "field1", "value1"],
      "expect": { "kind": "integer", "value": 1 }
    },
    {
      "name": "hget_existing_field",
      "now_ms": 0,
      "argv": ["HGET", "h1", "field1"],
      "expect": { "kind": "bulk", "value": "value1" }
    },
    {
      "name": "hget_missing_field",
      "now_ms": 0,
      "argv": ["HGET", "h1", "nosuch"],
      "expect": { "kind": "bulk", "value": null }
    },
    {
      "name": "hget_missing_key",
      "now_ms": 0,
      "argv": ["HGET", "nokey", "f"],
      "expect": { "kind": "bulk", "value": null }
    },
    {
      "name": "hset_multiple_fields",
      "now_ms": 0,
      "argv": ["HSET", "h1", "field2", "value2", "field3", "value3"],
      "expect": { "kind": "integer", "value": 2 }
    },
    {
      "name": "hset_update_existing_field",
      "now_ms": 0,
      "argv": ["HSET", "h1", "field1", "updated"],
      "expect": { "kind": "integer", "value": 0 }
    },
    {
      "name": "hget_updated_field",
      "now_ms": 0,
      "argv": ["HGET", "h1", "field1"],
      "expect": { "kind": "bulk", "value": "updated" }
    },
    {
      "name": "hdel_existing_field",
      "now_ms": 0,
      "argv": ["HDEL", "h1", "field2"],
      "expect": { "kind": "integer", "value": 1 }
    },
    {
      "name": "hdel_missing_field",
      "now_ms": 0,
      "argv": ["HDEL", "h1", "nosuch"],
      "expect": { "kind": "integer", "value": 0 }
    },
    {
      "name": "hexists_present",
      "now_ms": 0,
      "argv": ["HEXISTS", "h1", "field1"],
      "expect": { "kind": "integer", "value": 1 }
    },
    {
      "name": "hexists_absent",
      "now_ms": 0,
      "argv": ["HEXISTS", "h1", "field2"],
      "expect": { "kind": "integer", "value": 0 }
    },
    {
      "name": "hlen_hash",
      "now_ms": 0,
      "argv": ["HLEN", "h1"],
      "expect": { "kind": "integer", "value": 2 }
    },
    {
      "name": "hlen_missing_key",
      "now_ms": 0,
      "argv": ["HLEN", "nokey"],
      "expect": { "kind": "integer", "value": 0 }
    },
    {
      "name": "hmset_ok",
      "now_ms": 0,
      "argv": ["HMSET", "h2", "a", "1", "b", "2"],
      "expect": { "kind": "simple", "value": "OK" }
    },
    {
      "name": "hmget_fields",
      "now_ms": 0,
      "argv": ["HMGET", "h2", "a", "b", "c"],
      "expect": {
        "kind": "array",
        "value": [
          { "kind": "bulk", "value": "1" },
          { "kind": "bulk", "value": "2" },
          { "kind": "bulk", "value": null }
        ]
      }
    },
    {
      "name": "hincrby_new_field",
      "now_ms": 0,
      "argv": ["HINCRBY", "h2", "counter", "5"],
      "expect": { "kind": "integer", "value": 5 }
    },
    {
      "name": "hincrby_existing_field",
      "now_ms": 0,
      "argv": ["HINCRBY", "h2", "counter", "3"],
      "expect": { "kind": "integer", "value": 8 }
    },
    {
      "name": "hsetnx_new_field",
      "now_ms": 0,
      "argv": ["HSETNX", "h2", "new", "val"],
      "expect": { "kind": "integer", "value": 1 }
    },
    {
      "name": "hsetnx_existing_field",
      "now_ms": 0,
      "argv": ["HSETNX", "h2", "new", "other"],
      "expect": { "kind": "integer", "value": 0 }
    },
    {
      "name": "hstrlen_existing",
      "now_ms": 0,
      "argv": ["HSTRLEN", "h2", "new"],
      "expect": { "kind": "integer", "value": 3 }
    },
    {
      "name": "hstrlen_missing",
      "now_ms": 0,
      "argv": ["HSTRLEN", "h2", "nosuch"],
      "expect": { "kind": "integer", "value": 0 }
    },
    {
      "name": "hgetall_result",
      "now_ms": 0,
      "argv": ["HSET", "hga", "f1", "v1", "f2", "v2"],
      "expect": { "kind": "integer", "value": 2 }
    },
    {
      "name": "hgetall_missing_key",
      "now_ms": 0,
      "argv": ["HGETALL", "nokey"],
      "expect": { "kind": "array", "value": [] }
    },
    {
      "name": "hkeys_result",
      "now_ms": 0,
      "argv": ["HSET", "hk", "a", "1", "b", "2", "c", "3"],
      "expect": { "kind": "integer", "value": 3 }
    },
    {
      "name": "hkeys_missing_key",
      "now_ms": 0,
      "argv": ["HKEYS", "nokey"],
      "expect": { "kind": "array", "value": [] }
    },
    {
      "name": "hvals_missing_key",
      "now_ms": 0,
      "argv": ["HVALS", "nokey"],
      "expect": { "kind": "array", "value": [] }
    },
    {
      "name": "hincrbyfloat_new_field",
      "now_ms": 0,
      "argv": ["HINCRBYFLOAT", "hf", "price", "10.5"],
      "expect": { "kind": "bulk", "value": "10.5" }
    },
    {
      "name": "hincrbyfloat_existing",
      "now_ms": 0,
      "argv": ["HINCRBYFLOAT", "hf", "price", "0.3"],
      "expect": { "kind": "bulk", "value": "10.8" }
    },
    {
      "name": "hincrbyfloat_negative",
      "now_ms": 0,
      "argv": ["HINCRBYFLOAT", "hf", "price", "-0.8"],
      "expect": { "kind": "bulk", "value": "10" }
    },
    {
      "name": "hset_float_value",
      "now_ms": 0,
      "argv": ["HSET", "hf", "fval", "3.14"],
      "expect": { "kind": "integer", "value": 1 }
    },
    {
      "name": "hincrby_on_non_integer",
      "now_ms": 0,
      "argv": ["HINCRBY", "hf", "fval", "1"],
      "expect": { "kind": "error", "value": "ERR hash value is not an integer" }
    },
    {
      "name": "hset_wrongtype_on_string",
      "now_ms": 0,
      "argv": ["SET", "strkey", "val"],
      "expect": { "kind": "simple", "value": "OK" }
    },
    {
      "name": "hset_wrongtype_error",
      "now_ms": 0,
      "argv": ["HSET", "strkey", "f", "v"],
      "expect": { "kind": "error", "value": "WRONGTYPE Operation against a key holding the wrong kind of value" }
    },

    {
      "name": "hexists_missing_key",
      "now_ms": 100,
      "argv": ["HEXISTS", "nokey", "field"],
      "expect": { "kind": "integer", "value": 0 }
    },
    {
      "name": "hstrlen_missing_key",
      "now_ms": 101,
      "argv": ["HSTRLEN", "nokey", "field"],
      "expect": { "kind": "integer", "value": 0 }
    },
    {
      "name": "hmget_missing_key",
      "now_ms": 102,
      "argv": ["HMGET", "nokey", "a", "b"],
      "expect": {
        "kind": "array",
        "value": [
          { "kind": "bulk", "value": null },
          { "kind": "bulk", "value": null }
        ]
      }
    },

    {
      "name": "hdel_multiple_setup",
      "now_ms": 200,
      "argv": ["HSET", "hdm", "a", "1", "b", "2", "c", "3", "d", "4"],
      "expect": { "kind": "integer", "value": 4 }
    },
    {
      "name": "hdel_multiple_fields",
      "now_ms": 201,
      "argv": ["HDEL", "hdm", "a", "c", "z"],
      "expect": { "kind": "integer", "value": 2 }
    },
    {
      "name": "hlen_after_hdel_multiple",
      "now_ms": 202,
      "argv": ["HLEN", "hdm"],
      "expect": { "kind": "integer", "value": 2 }
    },
    {
      "name": "hdel_missing_key",
      "now_ms": 203,
      "argv": ["HDEL", "nokey", "field"],
      "expect": { "kind": "integer", "value": 0 }
    },

    {
      "name": "hgetall_setup",
      "now_ms": 300,
      "argv": ["HSET", "hga2", "name", "alice", "age", "30"],
      "expect": { "kind": "integer", "value": 2 }
    },
    {
      "name": "hgetall_result",
      "now_ms": 301,
      "argv": ["HGETALL", "hga2"],
      "expect": {
        "kind": "array",
        "value": [
          { "kind": "bulk", "value": "age" },
          { "kind": "bulk", "value": "30" },
          { "kind": "bulk", "value": "name" },
          { "kind": "bulk", "value": "alice" }
        ]
      }
    },
    {
      "name": "hkeys_setup",
      "now_ms": 310,
      "argv": ["HSET", "hk2", "x", "1", "y", "2", "z", "3"],
      "expect": { "kind": "integer", "value": 3 }
    },
    {
      "name": "hkeys_result",
      "now_ms": 311,
      "argv": ["HKEYS", "hk2"],
      "expect": {
        "kind": "array",
        "value": [
          { "kind": "bulk", "value": "x" },
          { "kind": "bulk", "value": "y" },
          { "kind": "bulk", "value": "z" }
        ]
      }
    },
    {
      "name": "hvals_result",
      "now_ms": 312,
      "argv": ["HVALS", "hk2"],
      "expect": {
        "kind": "array",
        "value": [
          { "kind": "bulk", "value": "1" },
          { "kind": "bulk", "value": "2" },
          { "kind": "bulk", "value": "3" }
        ]
      }
    },

    {
      "name": "hrandfield_setup_single",
      "now_ms": 400,
      "argv": ["HSET", "hrand1", "only_field", "only_value"],
      "expect": { "kind": "integer", "value": 1 }
    },
    {
      "name": "hrandfield_single_element",
      "now_ms": 401,
      "argv": ["HRANDFIELD", "hrand1"],
      "expect": { "kind": "bulk", "value": "only_field" }
    },
    {
      "name": "hrandfield_missing_key",
      "now_ms": 402,
      "argv": ["HRANDFIELD", "nokey"],
      "expect": { "kind": "bulk", "value": null }
    },
    {
      "name": "hrandfield_count_positive",
      "now_ms": 403,
      "argv": ["HRANDFIELD", "hrand1", "5"],
      "expect": {
        "kind": "array",
        "value": [
          { "kind": "bulk", "value": "only_field" }
        ]
      }
    },
    {
      "name": "hrandfield_count_zero",
      "now_ms": 404,
      "argv": ["HRANDFIELD", "hrand1", "0"],
      "expect": { "kind": "array", "value": [] }
    },
    {
      "name": "hrandfield_count_negative",
      "now_ms": 405,
      "argv": ["HRANDFIELD", "hrand1", "-3"],
      "expect": {
        "kind": "array",
        "value": [
          { "kind": "bulk", "value": "only_field" },
          { "kind": "bulk", "value": "only_field" },
          { "kind": "bulk", "value": "only_field" }
        ]
      }
    },
    {
      "name": "hrandfield_withvalues",
      "now_ms": 406,
      "argv": ["HRANDFIELD", "hrand1", "1", "WITHVALUES"],
      "expect": {
        "kind": "array",
        "value": [
          { "kind": "bulk", "value": "only_field" },
          { "kind": "bulk", "value": "only_value" }
        ]
      }
    },
    {
      "name": "hrandfield_missing_key_with_count",
      "now_ms": 407,
      "argv": ["HRANDFIELD", "nokey", "5"],
      "expect": { "kind": "array", "value": [] }
    },

    {
      "name": "hscan_setup",
      "now_ms": 500,
      "argv": ["HSET", "hscan_h", "alpha", "1", "beta", "2", "gamma", "3"],
      "expect": { "kind": "integer", "value": 3 }
    },
    {
      "name": "hscan_full",
      "now_ms": 501,
      "argv": ["HSCAN", "hscan_h", "0"],
      "expect": {
        "kind": "array",
        "value": [
          { "kind": "bulk", "value": "0" },
          {
            "kind": "array",
            "value": [
              { "kind": "bulk", "value": "alpha" },
              { "kind": "bulk", "value": "1" },
              { "kind": "bulk", "value": "beta" },
              { "kind": "bulk", "value": "2" },
              { "kind": "bulk", "value": "gamma" },
              { "kind": "bulk", "value": "3" }
            ]
          }
        ]
      }
    },
    {
      "name": "hscan_missing_key",
      "now_ms": 502,
      "argv": ["HSCAN", "nokey", "0"],
      "expect": {
        "kind": "array",
        "value": [
          { "kind": "bulk", "value": "0" },
          { "kind": "array", "value": [] }
        ]
      }
    },
    {
      "name": "hscan_with_match",
      "now_ms": 503,
      "argv": ["HSCAN", "hscan_h", "0", "MATCH", "a*"],
      "expect": {
        "kind": "array",
        "value": [
          { "kind": "bulk", "value": "0" },
          {
            "kind": "array",
            "value": [
              { "kind": "bulk", "value": "alpha" },
              { "kind": "bulk", "value": "1" }
            ]
          }
        ]
      }
    },

    {
      "name": "hincrby_negative",
      "now_ms": 600,
      "argv": ["HINCRBY", "h2", "counter", "-3"],
      "expect": { "kind": "integer", "value": 5 }
    },
    {
      "name": "hincrby_missing_key",
      "now_ms": 601,
      "argv": ["HINCRBY", "nokey", "field", "10"],
      "expect": { "kind": "integer", "value": 10 }
    },
    {
      "name": "hincrbyfloat_missing_key",
      "now_ms": 602,
      "argv": ["HINCRBYFLOAT", "nokey2", "field", "1.5"],
      "expect": { "kind": "bulk", "value": "1.5" }
    },

    {
      "name": "hset_wrong_arity",
      "now_ms": 700,
      "argv": ["HSET", "key"],
      "expect": {
        "kind": "error",
        "value": "ERR wrong number of arguments for 'HSET' command"
      }
    },
    {
      "name": "hget_wrong_arity",
      "now_ms": 701,
      "argv": ["HGET"],
      "expect": {
        "kind": "error",
        "value": "ERR wrong number of arguments for 'HGET' command"
      }
    },
    {
      "name": "hdel_wrong_arity",
      "now_ms": 702,
      "argv": ["HDEL"],
      "expect": {
        "kind": "error",
        "value": "ERR wrong number of arguments for 'HDEL' command"
      }
    },
    {
      "name": "hmget_wrong_arity",
      "now_ms": 703,
      "argv": ["HMGET"],
      "expect": {
        "kind": "error",
        "value": "ERR wrong number of arguments for 'HMGET' command"
      }
    },
    {
      "name": "hrandfield_wrong_arity",
      "now_ms": 704,
      "argv": ["HRANDFIELD"],
      "expect": {
        "kind": "error",
        "value": "ERR wrong number of arguments for 'HRANDFIELD' command"
      }
    },

    {
      "name": "hincrby_overflow_setup",
      "now_ms": 800,
      "argv": ["HSET", "hovf", "big", "9223372036854775806"],
      "expect": { "kind": "integer", "value": 1 }
    },
    {
      "name": "hincrby_near_max",
      "now_ms": 801,
      "argv": ["HINCRBY", "hovf", "big", "1"],
      "expect": { "kind": "integer", "value": 9223372036854775807 }
    },
    {
      "name": "hincrby_overflow_error",
      "now_ms": 802,
      "argv": ["HINCRBY", "hovf", "big", "1"],
      "expect": {
        "kind": "error",
        "value": "ERR increment or decrement would overflow"
      }
    },
    {
      "name": "hincrbyfloat_nan_error",
      "now_ms": 803,
      "argv": ["HINCRBYFLOAT", "hovf", "ff", "nan"],
      "expect": {
        "kind": "error",
        "value": "ERR value is not a valid float"
      }
    },
    {
      "name": "hincrbyfloat_inf_error",
      "now_ms": 804,
      "argv": ["HINCRBYFLOAT", "hovf", "ff", "inf"],
      "expect": {
        "kind": "error",
        "value": "ERR value is not a valid float"
      }
    },
    {
      "name": "wrongtype_setup_string_key",
      "now_ms": 808,
      "argv": ["SET", "strkey", "hello"],
      "expect": { "kind": "simple", "value": "OK" }
    },
    {
      "name": "hsetnx_wrongtype",
      "now_ms": 810,
      "argv": ["HSETNX", "strkey", "field", "value"],
      "expect": {
        "kind": "error",
        "value": "WRONGTYPE Operation against a key holding the wrong kind of value"
      }
    },
    {
      "name": "hgetall_empty_after_delete",
      "now_ms": 820,
      "argv": ["HSET", "hempty", "f1", "v1"],
      "expect": { "kind": "integer", "value": 1 }
    },
    {
      "name": "hgetall_empty_delete_field",
      "now_ms": 821,
      "argv": ["HDEL", "hempty", "f1"],
      "expect": { "kind": "integer", "value": 1 }
    },
    {
      "name": "hgetall_empty_hash_returns_empty",
      "now_ms": 822,
      "argv": ["HGETALL", "hempty"],
      "expect": {
        "kind": "array",
        "value": []
      }
    },
    {
      "name": "hmset_wrong_arity_odd",
      "now_ms": 830,
      "argv": ["HMSET", "h", "field"],
      "expect": {
        "kind": "error",
        "value": "ERR wrong number of arguments for 'HMSET' command"
      }
    },
    {
      "name": "hset_wrong_arity_odd",
      "now_ms": 831,
      "argv": ["HSET", "h", "field", "val", "orphan"],
      "expect": {
        "kind": "error",
        "value": "ERR wrong number of arguments for 'HSET' command"
      }
    },
    {
      "name": "hset_returns_new_count_only",
      "now_ms": 840,
      "argv": ["HSET", "h2", "counter", "newval", "newfield", "newval2"],
      "expect": { "kind": "integer", "value": 1 }
    },
    {
      "name": "hexists_wrong_arity",
      "now_ms": 850,
      "argv": ["HEXISTS"],
      "expect": {
        "kind": "error",
        "value": "ERR wrong number of arguments for 'HEXISTS' command"
      }
    },
    {
      "name": "hlen_wrong_arity",
      "now_ms": 851,
      "argv": ["HLEN"],
      "expect": {
        "kind": "error",
        "value": "ERR wrong number of arguments for 'HLEN' command"
      }
    },
    {
      "name": "hincrby_wrong_arity",
      "now_ms": 852,
      "argv": ["HINCRBY", "h"],
      "expect": {
        "kind": "error",
        "value": "ERR wrong number of arguments for 'HINCRBY' command"
      }
    },
    {
      "name": "hincrbyfloat_wrong_arity",
      "now_ms": 853,
      "argv": ["HINCRBYFLOAT", "h"],
      "expect": {
        "kind": "error",
        "value": "ERR wrong number of arguments for 'HINCRBYFLOAT' command"
      }
    },
    {
      "name": "hsetnx_wrong_arity",
      "now_ms": 854,
      "argv": ["HSETNX"],
      "expect": {
        "kind": "error",
        "value": "ERR wrong number of arguments for 'HSETNX' command"
      }
    },
    {
      "name": "hstrlen_wrong_arity",
      "now_ms": 855,
      "argv": ["HSTRLEN"],
      "expect": {
        "kind": "error",
        "value": "ERR wrong number of arguments for 'HSTRLEN' command"
      }
    },
    {
      "name": "hincrby_non_integer_increment",
      "now_ms": 860,
      "argv": ["HINCRBY", "h2", "counter", "abc"],
      "expect": {
        "kind": "error",
        "value": "ERR value is not an integer or out of range"
      }
    },
    {
      "name": "hrandfield_count_larger_than_hash",
      "now_ms": 870,
      "argv": ["HRANDFIELD", "hrand1", "10"],
      "expect": {
        "kind": "array",
        "value": [
          { "kind": "bulk", "value": "only_field" }
        ]
      }
    },
    {
      "name": "hrandfield_negative_with_duplicates",
      "now_ms": 871,
      "argv": ["HRANDFIELD", "hrand1", "-3"],
      "expect": {
        "kind": "array",
        "value": [
          { "kind": "bulk", "value": "only_field" },
          { "kind": "bulk", "value": "only_field" },
          { "kind": "bulk", "value": "only_field" }
        ]
      }
    },
    {
      "name": "hrandfield_negative_withvalues",
      "now_ms": 872,
      "argv": ["HRANDFIELD", "hrand1", "-2", "WITHVALUES"],
      "expect": {
        "kind": "array",
        "value": [
          { "kind": "bulk", "value": "only_field" },
          { "kind": "bulk", "value": "only_value" },
          { "kind": "bulk", "value": "only_field" },
          { "kind": "bulk", "value": "only_value" }
        ]
      }
    },

    {
      "name": "hdel_wrongtype",
      "now_ms": 880,
      "argv": ["HDEL", "strkey", "field"],
      "expect": {
        "kind": "error",
        "value": "WRONGTYPE Operation against a key holding the wrong kind of value"
      }
    },
    {
      "name": "hgetall_wrongtype",
      "now_ms": 881,
      "argv": ["HGETALL", "strkey"],
      "expect": {
        "kind": "error",
        "value": "WRONGTYPE Operation against a key holding the wrong kind of value"
      }
    },
    {
      "name": "hkeys_wrongtype",
      "now_ms": 882,
      "argv": ["HKEYS", "strkey"],
      "expect": {
        "kind": "error",
        "value": "WRONGTYPE Operation against a key holding the wrong kind of value"
      }
    },
    {
      "name": "hvals_wrongtype",
      "now_ms": 883,
      "argv": ["HVALS", "strkey"],
      "expect": {
        "kind": "error",
        "value": "WRONGTYPE Operation against a key holding the wrong kind of value"
      }
    }
  ]
}
